@require '../common/variables'

$arrow-icon-width = 16px
$post-nav-max-width = 220px
$article-title-font-size = 3.2rem
$temp-toc-width = hexo-config('global.sidebar_width')
$toc-container-width = $temp-toc-width ? convert($temp-toc-width) : 210px
$without-toc-container-width = calc(100% - $temp-toc-width)
$gap = 30px
$post-left-container-width = 240px
$post-article-min-width-before-hide-right = 620px
$post-article-min-width-before-hide-left = 620px
$post-hide-right-threshold = $post-article-min-width-before-hide-right + $post-left-container-width + $toc-container-width + ($gap * 2) + ($post-side-gutter * 2)
$post-hide-left-threshold = $post-article-min-width-before-hide-left + $post-left-container-width + $gap + ($post-side-gutter * 2)

.post-page-container
  display flex
  justify-content center
  position relative
  width 100%
  overflow visible

  +redefine-tablet()
    overflow-x hidden

  .article-content-container
    width 100%
    max-width $post-three-column-max-width
    redefine-container(
      false,
      0,
      0,
      0,
      30px
    )

    +redefine-mobile()
      padding 1.2rem 0.2rem
      box-shadow none !important
      max-width 100vw

    .article-header-meta-info
      margin-top 32px
      margin-bottom 16px

      +redefine-tablet()
        transform scale(0.9)
        transform-origin left top

    .article-content
      margin-top $spacing-unit
      padding-bottom 10px
      word-wrap break-word
      border-bottom 1px solid var(--border-color)
      color var(--default-text-color)

      &>:first-child
        margin-top 0 !important

    .article-prev, .article-next

        a
          position relative
          display block
          width 100%
          height 100%
          box-sizing border-box

          &.prev
            padding-left $arrow-icon-width

          &.next
            padding-right $arrow-icon-width

          .arrow-icon
            position absolute
            top 0
            height 100%
            width $arrow-icon-width

            &.left
              left 0

            &.right
              right 0

          .title
            width 100%
            height 100%

      .post-nav-item
        display none

        +redefine-tablet()
          display inline-block

      .post-nav-title-item
        overflow hidden
        text-overflow ellipsis
        white-space nowrap

        +redefine-tablet()
          display none

    .recommended-article
      overflow visible !important

      .recommended-mobile
        display none
        +redefine-tablet()
          display block

      .recommended-desktop
        display block
        +redefine-tablet()
          display none

      .recommended-article-group
        padding 10px 0
        display flex
        justify-content space-between
        flex-wrap wrap
        overflow visible !important

        @media screen and (max-width $device-tablet)
          height 190px
          overflow scroll

          &::-webkit-scrollbar
            width 0 !important

          -ms-overflow-style none

        .recommended-article-item
          redefine-container(
            false,
            0,
            0,
            10px,
            0
          )
          box-shadow var(--redefine-box-shadow-flat)
          padding 12px !important
          display flex
          flex-wrap wrap
          align-content center
          justify-content center
          align-items center
          overflow hidden
          width 32%
          max-height 200px
          margin-top: $gap * 0.5
          margin-right 0

          +redefine-tablet()
            width 49%

          img
            display flex
            width calc(100% + 24px)
            height 150px
            object-fit cover
            border-radius $redefine-border-radius-medium-top
            margin -12px -12px 0 -12px !important

          span
            margin-top 0.5rem
            display block
            display -webkit-box
            -webkit-box-orient vertical
            -webkit-line-clamp 1
            overflow hidden

  &.is-post-layout
    display grid
    align-items start
    justify-content center
    column-gap $gap
    grid-template-columns $post-left-container-width minmax(0, 1fr)
    width 100vw
    max-width none
    margin-left calc(50% - 50vw)
    padding 0 $post-side-gutter
    box-sizing border-box

    &.has-post-toc
      grid-template-columns $post-left-container-width minmax(0, 1fr) $toc-container-width

    .post-left-wrapper-absolute
      grid-column 1
      position sticky
      top $navbar-height + $spacing-unit
      align-self start
      margin-right 0
      height fit-content
      width 100%

    .article-content-container
      grid-column 2
      width 100%
      max-width none

    .toc-wrapper-absolute
      grid-column 3
      position sticky
      top $navbar-height + $spacing-unit
      align-self start
      margin-left 0
      height fit-content
      width 100%

  .post-left-wrapper-absolute
    position sticky
    top $navbar-height + $spacing-unit
    align-self start
    height fit-content
    width $post-left-container-width

  .post-left-content-container
    position relative
    width 100%
    max-height calc(100vh - 210px)
    display flex
    flex-direction column
    gap 12px

  .post-left-author-card, .post-left-category-card
    padding 12px
    border-radius $redefine-border-radius-large
    box-sizing border-box
    background var(--background-color)
    box-shadow var(--redefine-box-shadow-flat)
    border 1px solid var(--border-color)

  .left-card-title
    font-size 0.82rem
    color var(--third-text-color)
    margin-bottom 10px
    letter-spacing 0.03em

  .post-left-author-profile
    display flex
    align-items center
    gap 10px

    .avatar
      width 46px
      height 46px
      flex-shrink 0
      border-radius $redefine-border-radius-medium * 0.87
      border 1px solid var(--border-color)
      padding 1px
      box-sizing border-box

      img
        width 100%
        height 100%
        border-radius $redefine-border-radius-medium * 0.87

    .info
      min-width 0

    .name
      color var(--default-text-color)
      font-size 0.95rem
      font-weight 600
      line-height 1.35
      word-break break-word

    .author-label
      display inline-flex
      margin-top 6px
      border-radius $redefine-border-radius-small
      font-size 0.72rem
      line-height 1.2
      padding 2px 7px
      color var(--third-text-color)
      border 1px solid var(--shadow-color-1)

  .post-left-category-card
    display flex
    flex-direction column
    min-height 0
    flex 1

  .post-left-categories
    min-height 0
    flex 1
    overflow-y auto
    overflow-x hidden
    padding-right 4px

    &::-webkit-scrollbar
      width 6px

    &::-webkit-scrollbar-track
      background transparent

    &::-webkit-scrollbar-thumb
      border-radius 20px
      border 2px solid rgba(183, 183, 183, 0.2)

    .post-left-category-nav-list, .post-left-category-nav-list-child
      list-style none
      margin 0
      padding 0

    .post-left-category-nav-list-item
      margin-bottom 8px
      line-height 1.6

      &:last-child
        margin-bottom 0

    .post-left-category-nav-list-link
      color var(--second-text-color)
      text-decoration none
      transition color 0.2s ease

      &:hover
        color var(--primary-color)

    .post-left-category-nav-list-count
      margin-left 6px
      color var(--third-text-color)
      font-size 0.75rem

    .post-left-category-nav-list-child
      margin-top 6px
      margin-left 10px
      padding-left 10px
      border-left 1px dashed var(--border-color)

  .toc-wrapper-absolute
    position sticky
    top $navbar-height + $spacing-unit
    align-self start
    height fit-content
    width $toc-container-width

  .toc-content-container
    position relative
    display flex
    flex-direction column
    width 100%
    min-height 0
    height calc(100vh - 210px)
    max-height calc(100vh - 210px)
    overflow hidden
    padding 10px
    box-sizing border-box

    box-shadow none !important
    background transparent !important
    border none !important

    hover-style(
      false,
      0,
      0
    )

  figure.image-caption
    img
      margin-bottom 0

    figcaption
      margin-top 5px
      margin-bottom 10px
      text-align center
      font-size 0.9rem
      color var(--third-text-color)

@media screen and (max-width $post-hide-right-threshold)
  // Keep both sidebars fully visible while shrinking article.
  // Hide right TOC only when article reaches the suggested minimum width (760px).
  // threshold = article_min(760) + left + toc + gaps + side_gutters.
  .post-page-container.is-post-layout.has-post-toc
    grid-template-columns $post-left-container-width minmax(0, 1fr)

    .toc-wrapper-absolute
      display none !important

@media screen and (max-width $post-hide-left-threshold)
  // In two-column mode, continue shrinking article first.
  // Hide left sidebar when article reaches the suggested minimum width (620px).
  // threshold = article_min(620) + left + gap + side_gutters.
  .post-page-container.is-post-layout, .post-page-container.is-post-layout.has-post-toc
    grid-template-columns minmax(0, 1fr)
    justify-content stretch
    padding 0 $post-mobile-side-gutter

    .post-left-wrapper-absolute
      display none !important

    .article-content-container
      grid-column 1

@media screen and (min-width $post-three-column-max-width)
  // Cap 3-column layout width on ultra-wide screens and keep it centered.
  .post-page-container.is-post-layout.has-post-toc
    width $post-three-column-max-width
    margin-left s('calc(50% - %s)', ($post-three-column-max-width / 2))

// 针对有封面图的标题
.article-title-cover
  font-family 'OPPOSans', sans-serif !important 
  font-weight: 700

// 针对无封面图的标题 (常规)
.article-title-regular
  font-family 'OPPOSans', sans-serif !important 
  font-weight: 700

.article-tags-categories-container
  display flex
  flex-wrap wrap
  gap 8px
  margin-top 12px

.article-category-item, .article-tag-item
  display flex
  align-items center
  padding 4px 10px
  border-radius 16px
  background var(--third-background-color)
  color var(--second-text-color)
  font-size 0.9em
  font-family GlowSans-Compressed
  border 1px solid transparent
  transition all 0.2s ease
  
  &:hover
    background var(--second-background-color)
    transform translateY(-2px)
    box-shadow var(--redefine-deepest-shadow)

.article-category-item
  border 2px solid rgba(0, 0, 0, 0.1)
  
  &:hover
    background var(--primary-color)
    color #fff
    border-color var(--primary-color)

    i 
      color #fff
