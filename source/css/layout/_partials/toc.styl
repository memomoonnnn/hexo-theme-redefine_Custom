.post-toc-wrap
  $toc-level-gap = 14px
  $toc-line-inset = 0.4rem
  $toc-fade-edge = 14px
  $toc-fade-content-padding = 8px
  width 100%
  height 100%
  min-height 0
  font-size 0.92rem
  box-sizing border-box
  font-family $english-font-family, $chinese-font-family, 'Noto Sans', 'Noto Sans SC', sans-serif

  .post-toc
    display flex
    flex-direction column
    height 100%
    min-height 0

    .toc-title
      font-size 0.8rem
      color var(--default-text-color)
      font-weight 500
      margin-bottom 0.2rem
      flex-shrink 0

    .page-title
      white-space normal
      font-size 1.1rem
      color var(--second-text-color)
      font-weight bold
      margin-bottom 0.6rem
      flex-shrink 0

    ol
      list-style none
      margin 0
      padding 0 0 12px 0
      text-align left

      &:last-child
        padding-bottom 0

      > ol
        padding-left 0

      a
        transition-property all
        transition()

    .nav-item
      line-height 2
      font-size 0.9rem
      transition all 0.3s ease

      a
        position relative
        display inline-flex
        align-items center
        width 100%
        min-width 0
        padding-left $toc-level-gap

        &::before
          content ''
          width 2px
          height 1.1rem
          top 50%
          left 0
          transform translateY(-50%)
          border-radius 2px
          background var(--primary-color)
          position absolute
          z-index 1
          opacity 0
          transition all 0.1s linear

    .toc-nav-scroll
      position relative
      flex 1
      min-height 0
      overflow-y auto
      overflow-x hidden
      padding-top $toc-fade-content-padding
      padding-bottom $toc-fade-content-padding
      padding-left 0
      padding-right 4px
      overscroll-behavior contain
      -webkit-mask-image linear-gradient(to bottom, transparent 0, #000 $toc-fade-edge, #000 s('calc(100% - %s)', $toc-fade-edge), transparent 100%)
      mask-image linear-gradient(to bottom, transparent 0, #000 $toc-fade-edge, #000 s('calc(100% - %s)', $toc-fade-edge), transparent 100%)
      -webkit-mask-repeat no-repeat
      mask-repeat no-repeat
      -webkit-mask-size 100% 100%
      mask-size 100% 100%

      > .nav
        position relative

        &::before
          content ''
          position absolute
          top $toc-line-inset
          bottom $toc-line-inset
          left 0
          border-left 2px dotted var(--shadow-color-1)
          pointer-events none

      &:hover::-webkit-scrollbar-thumb
        border 2px solid rgba(183, 183, 183, 0.3)

      &::-webkit-scrollbar
        width 6px

      &::-webkit-scrollbar-track
        background transparent
        border none

      &::-webkit-scrollbar-thumb
        border-radius 20px
        border 2px solid rgba(183, 183, 183, 0)
        transition all 0.2s ease

      .nav-child
        position relative
        margin-left $toc-level-gap
        padding-left 0
        display hexo-config('articles.toc.expand') ? block : none

        &::before
          content ''
          position absolute
          top $toc-line-inset
          bottom $toc-line-inset
          left 0
          border-left 2px dotted var(--shadow-color-1)
          pointer-events none

      .active > .nav-child
        display block

      .active-current > .nav-child
        display block

        > .nav-item
          display block

      .nav-number, .nav-text
        color var(--third-text-color)
        transition all 0.3s ease

      .nav-number
        flex-shrink 0

      .nav-text
        min-width 0
        overflow hidden
        text-overflow ellipsis
        white-space nowrap

      .active > a
        .nav-number, .nav-text
          color var(--primary-color)
          font-weight bold

      .active-current
        .nav-number, .nav-text
          color var(--primary-color) !important
          font-weight bold
          transition all 0.3s ease
          // padding-left 12px

      .nav-item.active > a::before, .nav-item.active-current > a::before, a.active::before, a.active-current::before
          opacity 1
