.markdown-body
  /* [变量使用]: $english-font-family 等变量在 common/variables.styl 中定义 */
  font-family $english-font-family, $chinese-font-family, sans-serif
  font-size $default-article-font-size

  /* [嵌套选择器]: 这里的 blockquote 等同于 .markdown-body blockquote */
  blockquote
    /* [多重嵌套]: 等同于 .markdown-body blockquote p, .markdown-body blockquote ul ... */
    p, ul, ol
      padding 5px 5px 5px 10px

    box-sizing border-box
    margin 2em 3em
    color var(--default-text-color) /* [标准 CSS 变量]: 使用 var() 调用全局 CSS 变量 */
    font-style italic
    background var(--third-background-color)
    padding 0 1rem 0 0.5rem
    border-radius 0
    position relative
    border-left 5px solid var(--border-color)

  p
    line-height $default-line-height
    color var(--default-text-color)
    font-weight normal
    margin-bottom 1.5rem
    margin-top 1.5rem
    text-align justify

  a
    position relative
    outline 0
    text-decoration underline
    overflow-wrap break-word
    cursor pointer
    box-sizing border-box
    padding-bottom 2px
    text-underline-offset 2px
    text-decoration-color rgb(196, 160, 160)
    transition: text-decoration-color 0.2s ease

    /* [父级引用]: & 代表 a，所以 &.link 等同于 a.link */
    &.link
      padding-right 0.1em

    .fas, .far, fab
      margin 0 2px 0 6px
      position relative
      color var(--third-text-color)
      font-size 0.88rem

    .link-icon
      transition transform 0.2s ease

    /* [伪类嵌套]: & 代表 a，等同于 a:hover, a:focus */
    &:hover,
    &:focus
      text-decoration underline !important
      text-decoration-color rgb(246, 59, 59)!important 

      .link-icon
        transform translate(0.1em, -0.1em)

      /* [伪元素嵌套]: 等同于 a:hover::after 等 */
      &::after
        background #f63b3b
        text-decoration underline

  strong
    color var(--default-text-color)

  hr
    margin 2rem 0
    border 0
    border-top 2px solid var(--shadow-color-1)

  em
    color var(--default-text-color)

  /* 列表样式增强 */
  ul > li, ol > li
    color var(--second-text-color)
    margin-left 3em
    line-height $default-line-height
    &::marker
      color var(--border-color)

  ul
    margin-bottom 1.5rem
    li
      list-style disc
      ul
        li
          list-style circle
          ul
            li
              list-style square

  ol
    margin-bottom 1.5rem
    li
      list-style decimal
      ul
        li
          list-style disc
        ul
          li
            list-style circle
      ol
        li
          list-style upper-alpha
          ol
            li
              list-style upper-roman

  li
    color var(--default-text-color)

  /* 标题群组样式 */
  h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6
    font-family $english-font-family, $chinese-font-family, sans-serif
    color var(--second-text-color)
    line-height $default-line-height

    /* [Mixin 调用]: +redefine-tablet() 会生成针对平板电脑的媒体查询 */
    +redefine-tablet()
      line-height: $default-line-height * 0.96

  /* 各级标题具体设置 */
  h1, .h1
    font-size 2.5rem
    font-weight 650
    padding-bottom 1.5rem /* padding-bottom 控制文字与下边框的间距 */
    border-bottom solid 5px var(--fourth-text-color)
    margin-top $h1-heading-margin-top /* [变量使用]: 从配置读取的上边距 */
    margin-bottom 1rem
    letter-spacing -0.025em
    line-height 1.2

    +redefine-tablet()
      font-size 1.7rem
      line-height 1.2

  h2, .h2
    font-size 1.8rem
    font-weight 650
    // padding 3px 0
    // border-bottom solid 2px var(--fourth-text-color)
    margin-top $h2-heading-margin-top
    margin-bottom 1rem
    letter-spacing -0.025em
    line-height 1.1

    +redefine-tablet()
      font-size 1.6rem
      line-height 1.1

  h3, .h3
    font-size 1.5rem
    font-weight 600
    margin-top $h3-heading-margin-top
    margin-bottom 0.75rem
    letter-spacing -0.025em
    line-height 1.3

    +redefine-tablet()
      font-size 1.5rem
      line-height 1.2

  h4, .h4
    font-size 1.38rem
    font-weight 600
    margin-top $h4-heading-margin-top
    margin-bottom 0.75rem
    line-height 1.4

    +redefine-tablet()
      font-size 1.4rem
      line-height 1.3

  h5, .h5
    font-size 1.2rem
    font-weight 600
    margin-top $h5-heading-margin-top
    margin-bottom 0.5rem
    line-height 1.3

    +redefine-tablet()
      font-size 1.18rem
      line-height 1.2

  h6, .h6
    font-size 1.1rem
    font-weight 600
    margin-top $h6-heading-margin-top
    margin-bottom 0.5rem
    line-height 1.2

    +redefine-tablet()
      font-size 1.1rem
      line-height 1.1

  // img
  //   box-sizing border-box
  //   border-radius $usr-img-border-radius
  //   max-width 100%
  //   cursor zoom-in
  //   display block
  //   /* [自定义函数]: transition-t() 是在 animated.styl 中定义的 mixin，用于简化过度的编写 */
